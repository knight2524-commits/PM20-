rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tasks
    // Fields: title, description, assigneeId, assigneeName, priority, status, dueDate, createdAt, progress, alarms
    //
    // Collection: assignees
    // Fields: name, password, note
    //
    // Collection: notifications
    // Fields: title, message, type, timestamp, read, userId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "knight2524@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Validation Functions
    function isValidTask(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.assigneeIds is list &&
             data.assigneeNames is list &&
             data.status in ['todo', 'in-progress', 'done'] &&
             data.priority in ['low', 'medium', 'high'];
    }

    function isValidAssignee(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.password is string && data.password.size() > 0;
    }

    function isValidNotification(data) {
      return data.title is string && data.message is string &&
             data.type in ['info', 'warning', 'success', 'error'] &&
             data.timestamp is string &&
             data.read is bool &&
             (data.userId is string || !('userId' in data));
    }

    // Rules
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
