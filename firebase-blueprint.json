{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task assigned to team members.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the task." },
        "description": { "type": "string", "description": "A detailed description of the task." },
        "assigneeIds": { "type": "array", "items": { "type": "string" }, "description": "The IDs of the assignees." },
        "assigneeNames": { "type": "array", "items": { "type": "string" }, "description": "The names of the assignees." },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "The priority level." },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"], "description": "The current status." },
        "dueDate": { "type": "string", "format": "date", "description": "The due date (YYYY-MM-DD)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The creation timestamp." },
        "progress": { "type": "number", "description": "The progress percentage (0-100)." },
        "isMonthly": { "type": "boolean" },
        "repeatMonthly": { "type": "boolean" },
        "alarmTime": { "type": "string" }
      },
      "required": ["title", "assigneeIds", "assigneeNames", "status", "createdAt"]
    },
    "Assignee": {
      "title": "Assignee",
      "description": "A team member who can be assigned tasks.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the team member." },
        "password": { "type": "string", "description": "The login password." },
        "note": { "type": "string", "description": "A personal note for the team member." },
        "role": { "type": "string", "enum": ["admin", "member"] }
      },
      "required": ["name", "password"]
    },
    "SpecialPromotion": {
      "title": "SpecialPromotion",
      "description": "Special promotion information.",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "orderCode": { "type": "string" },
        "productName": { "type": "string" },
        "productNumber": { "type": "string" },
        "discountRate": { "type": "number" },
        "discountPrice": { "type": "number" },
        "description": { "type": "string" },
        "assigneeId": { "type": "string" },
        "assigneeName": { "type": "string" },
        "status": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "promotionData": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["brand", "productName", "discountPrice", "createdAt"]
    },
    "CompetitivePrice": {
      "title": "CompetitivePrice",
      "description": "Competitive price information.",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "memo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" }
      },
      "required": ["brand", "memo", "createdAt", "authorId"]
    },
    "Ledger": {
      "title": "Ledger",
      "description": "Ledger status for team members.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assigneeId": { "type": "string" },
        "assigneeName": { "type": "string" },
        "ledgerData": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "assigneeId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["title", "message", "type", "timestamp", "read", "userId"]
    }
  },
  "firestore": {
    "/special_promotions/{promotionId}": {
      "schema": "SpecialPromotion",
      "description": "Collection of special promotions."
    },
    "/competitive_prices/{priceId}": {
      "schema": "CompetitivePrice",
      "description": "Collection of competitive prices."
    },
    "/ledgers/{ledgerId}": {
      "schema": "Ledger",
      "description": "Collection of ledger status entries."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Collection of all tasks."
    },
    "/assignees/{assigneeId}": {
      "schema": "Assignee",
      "description": "Collection of all team members."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of user notifications."
    }
  }
}
